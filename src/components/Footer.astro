---
const year = new Date().getFullYear();
---

<footer class="site-footer">
  <div class="container footer-inner">
    <span>&copy; {year} Svetlana Karslioglu</span>
    <span class="links">
      <a href="https://www.linkedin.com/in/svetlana-karslioglu" rel="me">LinkedIn</a>
      <a href="https://github.com/svekars" rel="me">GitHub</a>
    </span>
  </div>
</footer>

<style>
  .site-footer {
    border-top: 1px solid var(--color-border);
    margin-top: 4rem;
    padding: 1.5rem 0;
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--color-muted);
  }
  .footer-inner {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 0.5rem;
  }
  .links {
    display: flex;
    gap: 1rem;
  }
  .site-footer a {
    color: var(--color-muted);
    border-bottom: 0;
  }
  .site-footer a:hover {
    color: var(--color-text);
  }
</style>
