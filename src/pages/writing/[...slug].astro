---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const entries = await getCollection('writing', ({ data }) => !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const formatDate = (d: Date) =>
  d.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });
---

<BaseLayout title={`${entry.data.title}, Svetlana Karslioglu`} description={entry.data.description}>
  <article>
    <header class="post-header">
      <span class="eyebrow"><a href="/writing">Writing</a></span>
      <h1>{entry.data.title}</h1>
      <time datetime={entry.data.date.toISOString()} class="muted">{formatDate(entry.data.date)}</time>
    </header>
    <div class="post-body">
      <Content />
    </div>
  </article>
</BaseLayout>

<style>
  .post-header {
    padding: 3rem 0 1.5rem;
  }
  .post-header h1 {
    margin: 0.25rem 0 0.5rem;
  }
  .post-body :global(h2) {
    margin-top: 2rem;
  }
  .post-body :global(pre) {
    background: #f4f1ea;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    padding: 1rem;
    overflow-x: auto;
    font-size: 0.9rem;
  }
  .post-body :global(blockquote) {
    border-left: 3px solid var(--color-border);
    margin: 1rem 0;
    padding: 0.25rem 0 0.25rem 1rem;
    color: var(--color-muted);
    font-style: italic;
  }
  .post-body :global(.infographic) {
    margin: 2.5rem 0;
    padding: 1.5rem 1rem 1rem;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: 6px;
  }
  .post-body :global(.infographic svg) {
    display: block;
    width: 100%;
    max-width: 640px;
    height: auto;
    margin: 0 auto;
  }
  .post-body :global(.infographic figcaption) {
    font-size: 0.85rem;
    color: var(--color-muted);
    margin: 0.75rem auto 0;
    max-width: 560px;
    text-align: center;
    line-height: 1.5;
  }
</style>
